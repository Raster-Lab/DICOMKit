<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ╔══════════════════════════════════════════════════════════════════╗
	     ║  ⚠️  TESTING-ONLY: App Sandbox is DISABLED (set to <false/>).      ║
	     ║  This is required so the CLI Workshop can spawn the real           ║
	     ║  `dicom-info` binary for the dicom-info "Compare CLI (TEST)"        ║
	     ║  side-by-side parity check (see DicomInfoTerminalCompare.swift).    ║
	     ║  BEFORE PRODUCTION: set this back to <true/> and remove the         ║
	     ║  terminal-compare feature. Memory: dicom-info-terminal-compare-     ║
	     ║  testonly.                                                          ║
	     ╚══════════════════════════════════════════════════════════════════╝ -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<key>com.apple.security.files.bookmarks.app-scope</key>
	<true/>
	<key>com.apple.security.files.downloads.read-write</key>
	<true/>
	<!-- CLI Workshop testing folders: grant the sandboxed app read/write to the
	     default DICOM input/output directories so typed/default paths work
	     without a manual open-panel selection. (Development convenience.) -->
	<key>com.apple.security.temporary-exception.files.absolute-path.read-write</key>
	<array>
		<string>/Users/raster/Desktop/DICOM_Input/</string>
		<string>/Users/raster/Desktop/DICOM_Output/</string>
	</array>
</dict>
</plist>
